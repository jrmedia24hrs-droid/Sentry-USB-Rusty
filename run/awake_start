#!/bin/bash -eu

if [[ ( -z "${TESLAFI_API_TOKEN:+x}" ) && ( -z "${TESSIE_API_TOKEN:+x}" ) && ( -z "${TESLA_BLE_VIN:+x}" ) && ( -z "${KEEP_AWAKE_WEBHOOK_URL:+x}" ) ]]
then
  log "Not configured to keep car awake."
else
  # ---------------------------------------------------------------------------
  # BLE radio management
  #
  # When Tesla BLE keep-awake is active, the GATT daemon (mobile-app Bluetooth)
  # is disabled for the entire session so tesla-control has exclusive, clean
  # access to hci0.  The daemon is restored by awake_stop when keep-awake ends.
  #
  # The lock file at /tmp/ble_radio_owner serializes access between this
  # script (owner string "keep_awake") and the telemetry sampler
  # (owner string "telemetry") — same path/format the sampler's
  # crates/tesla_telemetry/src/lock.rs uses.  File format:
  #     <owner>\n<unix_seconds>\n
  #
  # Failsafes:
  #   - awake_stop checks for active nudge loops before restoring, so an
  #     overlapping archive + webui keep-awake won't prematurely restore.
  #   - sentryusb-ble.service clears stale lock files on startup (boot/crash).
  #   - Lock files older than 24h are treated as stale and cleaned up.
  #
  # Keep-awake BLE switch: the user-facing settings toggle writes
  # BLE_KEEP_AWAKE_ENABLED=no to the config when they disable the
  # BLE keep-awake nudge specifically (independent of telemetry).
  # Honor it here even when a VIN is configured.
  # ---------------------------------------------------------------------------
  BLE_LOCK="/tmp/ble_radio_owner"
  BLE_LOCK_OWNER="keep_awake"

  # Maximum age (seconds) before a lock file is considered stale.
  BLE_LOCK_MAX_AGE=86400  # 24 hours

  # BLE keep-awake is now controlled by its own dedicated flag,
  # independent of the telemetry-side `BLE_ENABLED`. Users who only
  # want telemetry can leave keep-awake off, and vice versa. Existing
  # installs get migrated to the new flag at API startup via
  # `migrate_legacy_ble_flag` in crates/api/src/ble.rs.
  #
  # We re-read the value from /root/sentryusb.conf rather than using
  # the inherited env var. archiveloop sources the conf once at
  # process start, so a toggle flip in the web UI doesn't reach the
  # running process — its env still has the boot-time value. Reading
  # the file fresh on every call picks up live changes without
  # requiring an archiveloop restart.
  ble_is_enabled() {
    local current=""
    if [ -f /root/sentryusb.conf ]; then
      current=$(grep -E '^[[:space:]]*export[[:space:]]+BLE_KEEP_AWAKE_ENABLED=' \
        /root/sentryusb.conf 2>/dev/null \
        | tail -n1 \
        | sed -E "s/^[[:space:]]*export[[:space:]]+BLE_KEEP_AWAKE_ENABLED=//; s/^['\"]//; s/['\"]$//")
    fi
    case "$current" in
      yes|true|1) return 0 ;;
      *) return 1 ;;
    esac
  }

  ble_disable_gatt_daemon() {
    # Fast path: telemetry daemon IPC. If the daemon is running and
    # listening on its action socket, sentryusb-ble-action will
    # pipe each keep-awake command in via the socket and the daemon
    # will dispatch through its already-warm PersistentSession.
    # That means we don't have to stop the iOS GATT daemon, we
    # don't have to stop telemetry, we don't even have to grab the
    # BLE lock — the daemon serializes everything internally via
    # its own mpsc channel. This is the win that makes telemetry
    # keep updating during a long archive cycle.
    if [ -S /tmp/sentryusb-telemetry.sock ]; then
      log "Tesla BLE: telemetry IPC socket present — routing keep-awake actions through running daemon (no service stops needed)"
      return
    fi

    # Fallback path: no telemetry daemon listening. Either BLE
    # telemetry is disabled in settings, or the daemon crashed.
    # Run the original direct-BLE prep — stop everything that
    # touches the radio, take the lock as keep_awake, leave it
    # held until ble-action finishes opening its own connection.

    # If lock exists, check if it's stale OR owned by someone else
    # before trusting it as ours.
    if [ -e "$BLE_LOCK" ]; then
      local lock_age existing_owner
      lock_age=$(( $(date +%s) - $(stat -c %Y "$BLE_LOCK" 2>/dev/null || echo 0) ))
      existing_owner=$(head -n1 "$BLE_LOCK" 2>/dev/null || echo "")
      if [ "$lock_age" -gt "$BLE_LOCK_MAX_AGE" ]; then
        log "Tesla BLE: Stale lock detected (${lock_age}s old, owner='${existing_owner}') — cleaning up."
        rm -f "$BLE_LOCK"
      elif [ "$existing_owner" = "$BLE_LOCK_OWNER" ]; then
        log "Tesla BLE: GATT daemon already disabled for keep-awake (lock exists)."
        return
      else
        log "Tesla BLE: Radio held by '${existing_owner}' — taking over for keep-awake."
        # Fall through and overwrite — keep-awake is the higher-priority
        # caller (telemetry is best-effort, keep-awake prevents USB-power-off).
      fi
    fi

    log "Tesla BLE: Disabling mobile-app Bluetooth for keep-awake session..."
    systemctl stop sentryusb-ble 2>/dev/null || true

    # Also stop the telemetry sampler if it's running so it doesn't
    # fight us for the radio mid-session.
    systemctl stop sentryusb-telemetry 2>/dev/null || true

    # Wait for the daemon process to fully exit (up to 5 s).
    local _i
    for _i in $(seq 1 10); do
      pgrep -f 'sentryusb-ble\.py' >/dev/null 2>&1 || break
      sleep 0.5
    done

    if pgrep -f 'sentryusb-ble\.py' >/dev/null 2>&1; then
      log "Tesla BLE: Warning — GATT daemon still running after 5 s, killing."
      pkill -9 -f 'sentryusb-ble\.py' 2>/dev/null || true
      sleep 0.5
    fi

    # Give BlueZ a moment to finish cleaning up HCI state.
    sleep 1

    # Verify hci0 is UP; bring it up if BlueZ left it down.
    if command -v hciconfig >/dev/null 2>&1; then
      if ! hciconfig hci0 2>/dev/null | grep -q "UP RUNNING"; then
        log "Tesla BLE: hci0 not UP — bringing it up."
        hciconfig hci0 up 2>/dev/null || true
        sleep 0.5
      fi
    fi

    # Write the new-format lock file: <owner>\n<unix_seconds>\n.
    # Atomic-ish via tmp + mv since /tmp is tmpfs.
    {
      echo "$BLE_LOCK_OWNER"
      date +%s
    } > "${BLE_LOCK}.tmp"
    mv "${BLE_LOCK}.tmp" "$BLE_LOCK"
    log "Tesla BLE: Mobile-app Bluetooth disabled. hci0 reserved for tesla-control."
  }

  # Self-heal: if BLE keep-awake is enabled but sentryusb-ble-action
  # is missing (typical cause: the in-app updater ran but its
  # best-effort fetch of the binary silently failed, leaving the
  # user with a new awake_start script that references a binary
  # that isn't there), pull it down on demand from the latest
  # release. Falls through gracefully on any failure — subsequent
  # BLE calls will still log "No such file or directory" and retry,
  # but the user will see the recovery attempt in the log first.
  # One-shot per missing-binary event; healthy installs skip this
  # whole block since `-x` succeeds on the existing binary.
  if [[ -n "${TESLA_BLE_VIN:+x}" ]] && ble_is_enabled && [ ! -x /root/bin/sentryusb-ble-action ]; then
    log "Tesla BLE: /root/bin/sentryusb-ble-action missing — attempting one-shot fetch from latest release."
    _arch=$(uname -m 2>/dev/null || echo unknown)
    case "$_arch" in
      aarch64|arm64) _suffix="linux-arm64" ;;
      armv7l)        _suffix="linux-armv7" ;;
      armv6l)        _suffix="linux-armv6" ;;
      *)             _suffix="" ;;
    esac
    if [ -n "$_suffix" ]; then
      _url="https://github.com/Sentry-Six/Sentry-USB-Rusty/releases/latest/download/sentryusb-ble-action-${_suffix}"
      mkdir -p /root/bin
      if curl -fsSL --max-time 60 "$_url" -o /tmp/sentryusb-ble-action.fetch; then
        chmod +x /tmp/sentryusb-ble-action.fetch
        mv /tmp/sentryusb-ble-action.fetch /root/bin/sentryusb-ble-action
        log "Tesla BLE: Successfully fetched sentryusb-ble-action from $_url"
      else
        log "Tesla BLE: Failed to fetch sentryusb-ble-action from $_url — keep-awake BLE calls will continue to fail. Re-run the in-app update or wget the binary manually."
        rm -f /tmp/sentryusb-ble-action.fetch
      fi
    else
      log "Tesla BLE: Unknown architecture '$_arch' — cannot auto-fetch sentryusb-ble-action. Install it manually."
    fi
    unset _arch _suffix _url
  fi

  # If Tesla BLE is configured AND user hasn't disabled it in settings,
  # disable the GATT daemon once for the session.
  if [[ -n "${TESLA_BLE_VIN:+x}" ]] && ble_is_enabled; then
    ble_disable_gatt_daemon
  elif [[ -n "${TESLA_BLE_VIN:+x}" ]]; then
    log "Tesla BLE: VIN configured but BLE_KEEP_AWAKE_ENABLED=no — skipping BLE keep-awake path."
  fi

  # Returns a label like "Archive", "Drive Processing", "Manual (8m left)"
  function nudge_label {
    local label="${KEEP_AWAKE_REASON:-Keep Awake}"
    if [ -n "${KEEP_AWAKE_EXPIRES_AT:-}" ]; then
      local now remaining
      now=$(date +%s)
      remaining=$((KEEP_AWAKE_EXPIRES_AT - now))
      if [ "$remaining" -gt 0 ]; then
        label="$label ($((remaining / 60))m left)"
      fi
    fi
    echo "$label"
  }

  function nudge {
    local retry=1

    # Send a notification when the final nudge attempt fails
    function notify_nudge_failure {
      local provider="$1"
      local reason="$2"
      /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
        "${provider}: Keep awake failed (attempt 3/3). ${reason}" "" "keep_awake_failure" || true
    }

    while true
    do
      if [[ -n "${TESSIE_API_TOKEN:+x}" ]]
      # Use Tessie API to nudge the car
      then
        http_response=$(curl -s --connect-timeout 10 --max-time 30 -w "%{http_code}" \
          -H "Authorization: Bearer $TESSIE_API_TOKEN" \
          -H "Accept: application/json" \
          -H "User-Agent: github.com/Sentry-Six/Sentry-USB-Rusty" \
          "https://api.tessie.com/$TESSIE_VIN/command/close_charge_port")

        # Extract HTTP status code
        http_status="${http_response: -3}"

        # Check if HTTP status code is not 200 (OK)
        if [ "$http_status" != "200" ]
        then
          # Build a descriptive error reason based on HTTP status
          case "$http_status" in
            401) nudge_reason="Invalid or expired API token." ;;
            403) nudge_reason="API token lacks permission for this vehicle." ;;
            404) nudge_reason="Vehicle not found. Check VIN." ;;
            408) nudge_reason="Command timed out (Tesla Fleet API). Vehicle may be asleep or out of range." ;;
            429) nudge_reason="Too many requests. Rate limited." ;;
            500|502|503) nudge_reason="Tessie server error." ;;
            *)   nudge_reason="Check API token and VIN. Car may be offline or asleep." ;;
          esac
          log "Tessie: Failed to send nudge (HTTP $http_status). $nudge_reason"
          if [ "$retry" -lt "3" ]
          then
            log "Tessie: Retrying after 30s (attempt $((retry+1))/3)..."
            retry=$((retry+1))
            sleep 30
            continue
          else
            log "Tessie: Giving up after 3 attempts."
            notify_nudge_failure "Tessie" "HTTP $http_status — $nudge_reason"
            break
          fi
        else
          log "Tessie: Nudge OK [$(nudge_label)] (charge port close command sent)."
        fi
      fi

      if [[ -n "${TESLA_BLE_VIN:+x}" ]] && ble_is_enabled
      # use Tesla BLE API to nudge the car
      then
        # In-process bluez-based BLE — see crates/tesla_ble. Reads
        # VIN + BLE_ADAPTER from /root/sentryusb.conf, signs +
        # sends one charge-port-close, exits. Replaces the
        # tesla-control shell-out that previously needed
        # exclusive raw-HCI access (which is why we used to have
        # to stop the iOS GATT daemon for the whole session).
        if ! BLE_response=$(/root/bin/sentryusb-ble-action charge-port-close 2>&1)
        then
          # check false-negative BLE responses
          if [[ ( "$BLE_response" != *"already closed"* ) && ( "$BLE_response" != *"cable connected"* ) ]]
          then
            # log error and retry
            log "Tesla BLE: Failed to nudge the car. Response: $BLE_response"
            if [ "$retry" -lt "3" ]
            then
              log "Tesla BLE: Retrying after 30s (attempt $((retry+1))/3)..."
              retry=$((retry+1))
              sleep 30
              continue
            else
              log "Tesla BLE: Giving up after 3 attempts."
              notify_nudge_failure "Tesla BLE" "BLE command failed. Response: $BLE_response"
              break
            fi
          else
            log "Tesla BLE: Nudge OK [$(nudge_label)] (charge port already closed/cable connected)."
          fi
        else
          log "Tesla BLE: Nudge OK [$(nudge_label)]."
        fi

      elif [[ -n "${KEEP_AWAKE_WEBHOOK_URL:+x}" ]]
      # Use webhook to send nudge message
      then
        http_response=$(curl -s --connect-timeout 10 --max-time 30 -w "%{http_code}" POST \
          -d "{\"awake_command\":\"nudge\"}" \
          -H "Content-Type: application/json" \
          "$KEEP_AWAKE_WEBHOOK_URL")

        # Extract HTTP status code
        http_status="${http_response: -3}"

        # Check if HTTP status code is not 200 (OK)
        if [ "$http_status" -lt 200 ] || [ "$http_status" -ge 300 ]
        then
          log "Awake Webhook: Failed to send nudge (HTTP $http_status). Check if your KEEP_AWAKE_WEBHOOK_URL is set correctly."
          if [ "$retry" -lt "3" ]
          then
            log "Awake Webhook: Retrying after 30s (attempt $((retry+1))/3)..."
            retry=$((retry+1))
            sleep 30
            continue
          else
            log "Awake Webhook: Giving up after 3 attempts."
            notify_nudge_failure "Webhook" "HTTP status $http_status. Check KEEP_AWAKE_WEBHOOK_URL."
            break
          fi
        else
          log "Awake Webhook: Nudge sent [$(nudge_label)]."
        fi
      fi

      sleep 300
      retry=1
    done
  }

  case "${SENTRY_CASE}" in
    1 | 2)
      if [[ ( -n "${TESLAFI_API_TOKEN:+x}" ) ]]
      # Use TeslaFi API to enable Sentry Mode
      then
        http_response=$(curl -s --connect-timeout 10 --max-time 30 -w "%{http_code}" \
          -H "Authorization: Bearer $TESLAFI_API_TOKEN" \
          -H "Accept: application/json" \
          -H "User-Agent: github.com/Sentry-Six/Sentry-USB-Rusty" \
          "https://www.teslafi.com/feed.php?command=set_sentry_mode&sentryMode=true&noWake=true")

        log "TeslaFi: Command sent to enable Sentry Mode."

        # Extract HTTP status code
        http_status="${http_response: -3}"

        # Extract response body (excluding status code)
        response_body="${http_response:0:${#http_response}-3}"

        # Check if HTTP status code is not 200 (OK)
        if [ "$http_status" != "200" ]
        then
          # Log an error
          log "TeslaFi: Failed to set Sentry Mode. Check your TESLAFI_API_TOKEN is set correctly. If it is, your car may be offline or asleep."
          /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
            "TeslaFi: Failed to enable Sentry Mode (HTTP $http_status). Check API token." "" "keep_awake_failure" || true
        else
          # Check if the response is in JSON format
          if ! jq -e . >/dev/null 2>&1 <<<"$response_body"
          then
            log "TeslaFi: Failed to set Sentry Mode."
            /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
              "TeslaFi: Failed to enable Sentry Mode. Invalid response from API." "" "keep_awake_failure" || true
          else
            # Parse JSON and check if "result" is true
            result1=$(jq -r '.response' <<<"$response_body")
            result2=$(jq -r '.result' <<<"$result1")
            request_counter=$(jq -r '.tesla_request_counter' <<<"$response_body")
            commands=$(jq -r '.commands' <<<"$request_counter")

            if [[ "$result2" = "true" ]]
            then
              log "TeslaFi: Sentry Mode Enabled. Monthly command counter = $commands."
            else
              log "TeslaFi: Failed to set Sentry Mode. Response data: $response_body"
              /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
                "TeslaFi: Failed to enable Sentry Mode. API returned failure." "" "keep_awake_failure" || true
            fi
          fi
        fi
      elif [[ -n "${TESSIE_API_TOKEN:+x}" ]]
      # Use Tessie API to enable Sentry Mode (up to 3 attempts)
      then
        tessie_attempt=1
        # shellcheck disable=SC2034
        tessie_success=false
        while [ "$tessie_attempt" -le 3 ]
        do
          http_response=$(curl -s --connect-timeout 10 --max-time 30 -w "%{http_code}" \
            -H "Authorization: Bearer $TESSIE_API_TOKEN" \
            -H "Accept: application/json" \
            -H "User-Agent: github.com/Sentry-Six/Sentry-USB-Rusty" \
            "https://api.tessie.com/$TESSIE_VIN/command/enable_sentry")

          log "Tessie: Command sent to enable Sentry Mode (attempt $tessie_attempt/3)."
          # Extract HTTP status code
          http_status="${http_response: -3}"

          # Extract response body (excluding status code)
          response_body="${http_response:0:${#http_response}-3}"

          # Try to extract error details from the response body
          tessie_error=""
          if jq -e . >/dev/null 2>&1 <<<"$response_body"; then
            tessie_error=$(jq -r '.error // empty' <<<"$response_body" 2>/dev/null)
          fi

          # Check if HTTP status code is not 200 (OK)
          if [ "$http_status" != "200" ]
          then
            # Build a descriptive error reason based on HTTP status
            case "$http_status" in
              401) tessie_reason="Invalid or expired API token." ;;
              403) tessie_reason="API token lacks permission for this vehicle." ;;
              404) tessie_reason="Vehicle not found. Check VIN." ;;
              408) tessie_reason="Command timed out (Tesla Fleet API). Vehicle may be asleep or out of range." ;;
              429) tessie_reason="Too many requests. Rate limited." ;;
              500|502|503) tessie_reason="Tessie server error." ;;
              *)   tessie_reason="Unexpected error." ;;
            esac
            # Append Tessie error detail if available
            if [ -n "$tessie_error" ]; then
              tessie_reason="$tessie_reason $tessie_error"
            fi
            log "Tessie: Failed to enable Sentry Mode (HTTP $http_status). $tessie_reason"
            if [ "$tessie_attempt" -lt 3 ]; then
              log "Tessie: Retrying after 30s (attempt $((tessie_attempt+1))/3)..."
              tessie_attempt=$((tessie_attempt+1))
              sleep 30
              continue
            else
              log "Tessie: Giving up after 3 attempts."
              /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
                "Tessie: Failed to enable Sentry Mode after 3 attempts (HTTP $http_status). $tessie_reason" "" "keep_awake_failure" || true
            fi
          else
            # Check if the response is in JSON format
            if ! jq -e . >/dev/null 2>&1 <<<"$response_body"
            then
              log "Tessie: Failed to enable Sentry Mode. Invalid response: $response_body"
              if [ "$tessie_attempt" -lt 3 ]; then
                log "Tessie: Retrying after 30s (attempt $((tessie_attempt+1))/3)..."
                tessie_attempt=$((tessie_attempt+1))
                sleep 30
                continue
              else
                log "Tessie: Giving up after 3 attempts."
                /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
                  "Tessie: Failed to enable Sentry Mode after 3 attempts. Invalid API response." "" "keep_awake_failure" || true
              fi
            else
              # Parse JSON and check if "result" is true
              result=$(jq -r '.result' <<<"$response_body")
              if [[ "$result" == "true" ]]; then
                log "Tessie: Sentry Mode Enabled."
                # shellcheck disable=SC2034
                tessie_success=true
              else
                tessie_error=$(jq -r '.error // "unknown reason"' <<<"$response_body" 2>/dev/null)
                log "Tessie: API returned failure. $tessie_error"
                if [ "$tessie_attempt" -lt 3 ]; then
                  log "Tessie: Retrying after 30s (attempt $((tessie_attempt+1))/3)..."
                  tessie_attempt=$((tessie_attempt+1))
                  sleep 30
                  continue
                else
                  log "Tessie: Giving up after 3 attempts."
                  /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
                    "Tessie: Failed to enable Sentry Mode after 3 attempts. $tessie_error" "" "keep_awake_failure" || true
                fi
              fi
            fi
          fi
          break
        done
      elif [[ -n "${TESLA_BLE_VIN:+x}" ]] && ble_is_enabled
      # Use Tesla BLE API to enable Sentry Mode
      then
        # In-process bluez-based BLE — see crates/tesla_ble. Same
        # rationale as the charge-port-close call above: shared
        # radio with the iOS GATT daemon instead of monopolizing it.
        if /root/bin/sentryusb-ble-action sentry-on
        then
          log "Tesla BLE: Sentry Mode enabled [$(nudge_label)]."
        else
          log "Tesla BLE: Failed to enable Sentry Mode [$(nudge_label)]."
          /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
            "Tesla BLE: Failed to enable Sentry Mode via BLE." "" "keep_awake_failure" || true
        fi
      elif [[ -n "${KEEP_AWAKE_WEBHOOK_URL:+x}" ]]
      # Use webhook to send start command
      then
        http_response=$(curl -s --connect-timeout 10 --max-time 30 -w "%{http_code}" POST \
          -d "{\"awake_command\":\"start\"}" \
          -H "Content-Type: application/json" \
          "$KEEP_AWAKE_WEBHOOK_URL")

        log "Awake Webhook: Command sent \"start\""

        # Extract HTTP status code
        http_status="${http_response: -3}"

        # Check if HTTP status code is not 200 (OK)
        if [ "$http_status" -lt 200 ] || [ "$http_status" -ge 300 ]
        then
          # Log an error
          log "Awake Webhook: Failed to send command \"start\". Check if your KEEP_AWAKE_WEBHOOK_URL is set correctly. If it is, check the service receiving webhooks for logs."
          /root/bin/send-push-message "${NOTIFICATION_TITLE:-SentryUSB}:" \
            "Webhook: Failed to send start command (HTTP $http_status). Check KEEP_AWAKE_WEBHOOK_URL." "" "keep_awake_failure" || true
        fi
      fi
      ;;
    3)
      # Nudge car periodically without using Sentry Mode.
      # Use a single global PID file so only one nudge loop runs at a time.
      # Kill any existing loop first to prevent BLE contention when multiple
      # callers (archiveloop, webui) both request keep-awake.
      pid_file="/tmp/keep_awake_nudge_pid"
      if [ -e "$pid_file" ]; then
        kill "$(cat "$pid_file")" 2>/dev/null || true
        rm -f "$pid_file"
      fi
      # Clean up legacy per-caller PID files from older versions
      for pf in /tmp/keep_awake_archive_pid /tmp/keep_awake_webui_pid /tmp/keep_awake_task_pid; do
        if [ -e "$pf" ]; then
          kill "$(cat "$pf")" 2>/dev/null || true
          rm -f "$pf"
        fi
      done
      log "Starting background task to keep car awake."
      nudge &
      echo $! > "$pid_file"
      ;;
    *)
      log "Invalid or no SENTRY_CASE defined."
      ;;
  esac
fi
