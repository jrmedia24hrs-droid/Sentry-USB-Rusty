# Update config.txt if needed
# Pi 3 needs dr_mode=peripheral to ensure the DWC2 controller operates in
# gadget/peripheral mode rather than defaulting to host mode.
# Pi 4 and Pi 5 need the overlay under their model-specific [piN] section
# because modern Raspberry Pi OS (Bookworm) uses conditional sections in
# config.txt — a globally placed dtoverlay can be ignored.
if [ -f "$PICONFIG_PATH" ]
then
  if isPi3
  then
    if ! grep -q 'dtoverlay=dwc2,dr_mode=peripheral' "$PICONFIG_PATH"
    then
      sed -i '/^dtoverlay=dwc2$/d' "$PICONFIG_PATH"
      echo -e "dtoverlay=dwc2,dr_mode=peripheral\n" >> "$PICONFIG_PATH"
      setup_progress "rebooting to apply dwc2 overlay change (peripheral mode for Pi 3)"
      reboot
      exit 0
    fi
  elif isPi4
  then
    # Ensure [pi4] section exists with dtoverlay=dwc2.
    # Remove any stale global dtoverlay=dwc2 (left over from base image)
    # since Pi 4 needs it under the [pi4] conditional section.
    pi4_needs_reboot=false
    if grep -q '^\[pi4\]' "$PICONFIG_PATH"
    then
      # Section exists — check if dtoverlay=dwc2 is present within it
      if ! sed -n '/^\[pi4\]/,/^\[/p' "$PICONFIG_PATH" | grep -q 'dtoverlay=dwc2'
      then
        sed -i '/^\[pi4\]/a dtoverlay=dwc2' "$PICONFIG_PATH"
        pi4_needs_reboot=true
      fi
    else
      # No [pi4] section — create one
      if grep -q '^\[cm4\]' "$PICONFIG_PATH"
      then
        sed -i '/^\[cm4\]/i [pi4]\ndtoverlay=dwc2\n' "$PICONFIG_PATH"
      else
        printf '\n[pi4]\ndtoverlay=dwc2\n' >> "$PICONFIG_PATH"
      fi
      pi4_needs_reboot=true
    fi
    # Clean up global dtoverlay=dwc2 that is outside any section
    sed -i '/^\[/,$!{/^dtoverlay=dwc2$/d}' "$PICONFIG_PATH"
    if [ "$pi4_needs_reboot" = true ]
    then
      setup_progress "rebooting to apply dwc2 overlay change (Pi4 gadget mode)"
      reboot
      exit 0
    fi
  elif isPi5
  then
    # Ensure [pi5] section exists with dtoverlay=dwc2.
    # Remove any stale global dtoverlay=dwc2 (left over from base image)
    # since Pi 5 needs it under the [pi5] conditional section.
    pi5_needs_reboot=false
    if grep -q '^\[pi5\]' "$PICONFIG_PATH"
    then
      # Section exists — check if dtoverlay=dwc2 is present within it
      if ! sed -n '/^\[pi5\]/,/^\[/p' "$PICONFIG_PATH" | grep -q 'dtoverlay=dwc2'
      then
        sed -i '/^\[pi5\]/a dtoverlay=dwc2' "$PICONFIG_PATH"
        pi5_needs_reboot=true
      fi
    else
      # No [pi5] section — create one
      if grep -q '^\[cm5\]' "$PICONFIG_PATH"
      then
        sed -i '/^\[cm5\]/i [pi5]\ndtoverlay=dwc2\n' "$PICONFIG_PATH"
      else
        printf '\n[pi5]\ndtoverlay=dwc2\n' >> "$PICONFIG_PATH"
      fi
      pi5_needs_reboot=true
    fi
    # Clean up global dtoverlay=dwc2 that is outside any section
    sed -i '/^\[/,$!{/^dtoverlay=dwc2$/d}' "$PICONFIG_PATH"
    if [ "$pi5_needs_reboot" = true ]
    then
      setup_progress "rebooting to apply dwc2 overlay change (Pi5 gadget mode)"
      reboot
      exit 0
    fi
  elif isPi2
  then
    # Ensure [pi02] section exists with dtoverlay=dwc2.
    # The stock Bookworm config.txt has dtoverlay=dwc2 inside [cm5], so a
    # bare grep would wrongly conclude the overlay is already enabled — but
    # the [cm5] section does not apply to Pi Zero 2 W.
    pi02_needs_reboot=false
    if grep -q '^\[pi02\]' "$PICONFIG_PATH"
    then
      # Section exists — check if dtoverlay=dwc2 is present within it
      if ! sed -n '/^\[pi02\]/,/^\[/p' "$PICONFIG_PATH" | grep -q 'dtoverlay=dwc2'
      then
        sed -i '/^\[pi02\]/a dtoverlay=dwc2' "$PICONFIG_PATH"
        pi02_needs_reboot=true
      fi
    else
      # No [pi02] section — create one before [all] if possible
      if grep -q '^\[all\]' "$PICONFIG_PATH"
      then
        sed -i '/^\[all\]/i [pi02]\ndtoverlay=dwc2\n' "$PICONFIG_PATH"
      else
        printf '\n[pi02]\ndtoverlay=dwc2\n' >> "$PICONFIG_PATH"
      fi
      pi02_needs_reboot=true
    fi
    # Clean up global dtoverlay=dwc2 that is outside any section
    sed -i '/^\[/,$!{/^dtoverlay=dwc2$/d}' "$PICONFIG_PATH"
    if [ "$pi02_needs_reboot" = true ]
    then
      setup_progress "rebooting to apply dwc2 overlay change (Pi Zero 2 W gadget mode)"
      reboot
      exit 0
    fi
  else
    # Fallback for other boards (Pi Zero W, etc.)
    # Check that dtoverlay=dwc2 is present in the [all] section or globally
    # (before any [section] header), not just anywhere in the file — the
    # stock Bookworm config.txt has dtoverlay=dwc2 inside [cm5] which does
    # not apply to other boards.
    has_global_dwc2=false
    if sed -n '1,/^\[/p' "$PICONFIG_PATH" | grep -q 'dtoverlay=dwc2'
    then
      has_global_dwc2=true
    elif sed -n '/^\[all\]/,/^\[/p' "$PICONFIG_PATH" | grep -q 'dtoverlay=dwc2'
    then
      has_global_dwc2=true
    fi
    if [ "$has_global_dwc2" = false ]
    then
      if grep -q '^\[all\]' "$PICONFIG_PATH"
      then
        sed -i '/^\[all\]/a dtoverlay=dwc2' "$PICONFIG_PATH"
      else
        echo -e "dtoverlay=dwc2\n" >> "$PICONFIG_PATH"
      fi
      setup_progress "rebooting to apply dwc2 overlay change"
      reboot
      exit 0
    fi
  fi
fi

